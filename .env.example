# ==============================================================================
# Hermes Office Synergy Agent - 环境配置模板
# ==============================================================================
# 复制此文件为 .env 并填写真实配置值
# .env 文件已加入 .gitignore，不会被提交到版本控制

# ---------------------------
# API 密钥配置（敏感信息）
# ---------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
ZHIPU_API_KEY=
KIMI_API_KEY=
MOONSHOT_API_KEY=

# ---------------------------
# 数据库配置
# ---------------------------
DATABASE_PATH=./data/agent.db
VECTOR_DB_PATH=./data/vectors

# ---------------------------
# 服务器配置
# ---------------------------
PORT=3000
HOST=0.0.0.0
ALLOWED_ORIGINS=*
MAX_FILE_SIZE=52428800

# ---------------------------
# 日志配置
# ---------------------------
LOG_LEVEL=INFO

# ---------------------------
# 插件配置
# ---------------------------
IM_ADAPTER_TYPE=feishu          # feishu, dingtalk, wecom, slack, discord
MODEL_ROUTER_TYPE=ollama        # ollama, openai, anthropic, zhipu, moonshot, multi
MEMORY_STORE_TYPE=redis_hybrid  # chroma, simple, milvus, faiss, hybrid, redis_hybrid
SKILL_MANAGER_TYPE=hybrid       # database, file, hybrid
TOOL_EXECUTOR_TYPE=sandboxed    # basic, sandboxed

# ---------------------------
# Redis 配置（用于 redis_hybrid 记忆存储）
# ---------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_PREFIX=hermes:

# ---------------------------
# Milvus 配置（用于 milvus 记忆存储）
# ---------------------------
MILVUS_URI=
MILVUS_TOKEN=

# ---------------------------
# Ollama 配置
# ---------------------------
OLLAMA_HOST=http://localhost:11434

# ---------------------------
# 沙箱配置
# ---------------------------
SANDBOX_ALLOWED_PATHS=
SANDBOX_MAX_EXECUTION_TIME=30

# ---------------------------
# 飞书配置
# ---------------------------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_NAME=Hermes-Office-Synergy-Agent
FEISHU_CONNECTION_MODE=websocket

# ---------------------------
# 钉钉配置
# ---------------------------
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_TOKEN=

# ---------------------------
# 企业微信配置
# ---------------------------
WECOM_CORP_ID=
WECOM_APP_SECRET=
WECOM_AGENT_ID=

# ---------------------------
# 微信配置（个人号）
# ---------------------------
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ---------------------------
# Slack 配置
# ---------------------------
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ---------------------------
# Discord 配置
# ---------------------------
DISCORD_BOT_TOKEN=
